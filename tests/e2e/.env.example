# Copy this file to tests/e2e/.env and fill in the values.
# Used by tests/e2e/run-local.sh (local) and tests/e2e/run-vm.sh (cloud VM).
# tests/e2e/.env is gitignored.

# ---- GitHub (required for both scripts) ----
# A repo where the test can open throwaway PRs. The token must have access to it.
TEST_REPO=your-org/kodus-test-sandbox
# PAT with scopes: `repo` + `admin:repo_hook`
# Create at: https://github.com/settings/tokens
GH_TEST_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ---- Cloud VM provider (only for test-e2e-vm.sh) ----
# Default provider is digitalocean. Set TEST_VM_PROVIDER=hetzner to switch.
TEST_VM_PROVIDER=digitalocean

# DigitalOcean
# Create at: https://cloud.digitalocean.com/account/api/tokens
# Scopes: droplet (read+create+delete), ssh_key (read+create+delete)
DIGITALOCEAN_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxx
# Optional overrides:
# DO_REGION=nyc3
# DO_SIZE=s-2vcpu-4gb
# DO_IMAGE=ubuntu-24-04-x64

# Hetzner (only needed if TEST_VM_PROVIDER=hetzner)
# Create at: https://console.hetzner.cloud/ -> Project -> Security -> API Tokens (Read & Write)
# HCLOUD_TOKEN=xxxxxxxxxxxxxxxxxxxx
# HCLOUD_LOCATION=nbg1
# HCLOUD_SERVER_TYPE=cx22
# HCLOUD_IMAGE=ubuntu-24.04

# ---- ngrok (only for test-e2e.sh, the LOCAL variant) ----
# Not needed for test-e2e-vm.sh — it uses cloudflared on the VM instead.
# NGROK_AUTHTOKEN=xxxxxxxxxxxxxxxxxxxx

# ---- Optional test config ----
# Reuse an existing open PR instead of creating a new one each run.
# When set, the script pushes a new commit to the PR's branch (triggers
# pull_request.synchronize) instead of opening/closing throwaway PRs.
# Recommended: pre-open a long-lived PR on a dedicated branch in TEST_REPO.
# TEST_PR_NUMBER=42

# TEST_USER_EMAIL=e2e@kodus.test
# TEST_USER_PASSWORD=SomethingSecure!1
# TEST_TIMEOUT_REVIEW=600
# TEST_KEEP_RUNNING=0   # set to 1 to skip teardown when debugging
# SKIP_PLAYWRIGHT=0     # set to 1 to skip signup step
